{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Chang'an Night",
  "author": "mjnchen",
  "themes": [
    {
      "name": "Chang'an Night",
      "appearance": "dark",
      "style": {
        "border": "#262a3f",
        "border.variant": "#22253a",
        "border.focused": "#f4c860",
        "border.selected": "#f4c860",
        "border.transparent": "#00000000",
        "border.disabled": "#22253a",

        "background": "#1a1d2e",
        "elevated_surface.background": "#22253a",
        "surface.background": "#15172a",
        "drop_target.background": "#7a9ad440",

        "element.background": "#22253a",
        "element.hover": "#262a3f",
        "element.active": "#3a4060",
        "element.selected": "#3a4060",
        "element.disabled": "#22253a",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#22253a",
        "ghost_element.active": "#262a3f",
        "ghost_element.selected": "#3a4060",
        "ghost_element.disabled": "#00000000",

        "text": "#e8e4d4",
        "text.muted": "#bdb59d",
        "text.placeholder": "#5a5d70",
        "text.disabled": "#5a5d70",
        "text.accent": "#f4c860",

        "icon": "#e8e4d4",
        "icon.muted": "#bdb59d",
        "icon.disabled": "#5a5d70",
        "icon.placeholder": "#5a5d70",
        "icon.accent": "#f4c860",

        "status_bar.background": "#15172a",
        "title_bar.background": "#15172a",
        "title_bar.inactive_background": "#15172a",
        "toolbar.background": "#1a1d2e",
        "tab_bar.background": "#15172a",
        "tab.inactive_background": "#15172a",
        "tab.active_background": "#1a1d2e",
        "panel.background": "#15172a",
        "panel.focused_border": "#f4c860",
        "pane.focused_border": "#f4c860",
        "pane_group.border": "#262a3f",

        "search.match_background": "#d4a23f55",

        "scrollbar.thumb.background": "#3a3d4e88",
        "scrollbar.thumb.hover_background": "#5a5d70aa",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#1a1d2e",
        "scrollbar.track.border": "#262a3f",

        "editor.foreground": "#e8e4d4",
        "editor.background": "#1a1d2e",
        "editor.gutter.background": "#1a1d2e",
        "editor.subheader.background": "#15172a",
        "editor.active_line.background": "#22253a",
        "editor.highlighted_line.background": "#262a3f",
        "editor.line_number": "#3a3d4e",
        "editor.active_line_number": "#f4c860",
        "editor.invisible": "#3a3d4e",
        "editor.wrap_guide": "#262a3f",
        "editor.active_wrap_guide": "#3a3d4e",
        "editor.document_highlight.read_background": "#7a9ad433",
        "editor.document_highlight.write_background": "#f4c86033",

        "terminal.background": "#1a1d2e",
        "terminal.foreground": "#e8e4d4",
        "terminal.bright_foreground": "#f5efde",
        "terminal.dim_foreground": "#bdb59d",
        "terminal.ansi.black": "#0d0e1a",
        "terminal.ansi.red": "#c93f3f",
        "terminal.ansi.green": "#5a8c4a",
        "terminal.ansi.yellow": "#d4a23f",
        "terminal.ansi.blue": "#5a7aa8",
        "terminal.ansi.magenta": "#a04a64",
        "terminal.ansi.cyan": "#4a8c8c",
        "terminal.ansi.white": "#bdb59d",
        "terminal.ansi.bright_black": "#3a3d4e",
        "terminal.ansi.bright_red": "#e85a4a",
        "terminal.ansi.bright_green": "#7dc26d",
        "terminal.ansi.bright_yellow": "#f4c860",
        "terminal.ansi.bright_blue": "#7a9ad4",
        "terminal.ansi.bright_magenta": "#d48a9e",
        "terminal.ansi.bright_cyan": "#7ac0c0",
        "terminal.ansi.bright_white": "#f5efde",
        "terminal.ansi.dim_black": "#0d0e1a",
        "terminal.ansi.dim_red": "#a03333",
        "terminal.ansi.dim_green": "#46703a",
        "terminal.ansi.dim_yellow": "#a88033",
        "terminal.ansi.dim_blue": "#476186",
        "terminal.ansi.dim_magenta": "#7f3a4f",
        "terminal.ansi.dim_cyan": "#3a7070",
        "terminal.ansi.dim_white": "#9c947e",

