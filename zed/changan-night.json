        "created": "#7dc26d",
        "created.background": "#7dc26d22",
        "created.border": "#5a8c4a",
        "deleted": "#c93f3f",
        "deleted.background": "#c93f3f22",
        "deleted.border": "#c93f3f",
        "error": "#e85a4a",
        "error.background": "#e85a4a22",
        "error.border": "#e85a4a",
        "hidden": "#5a5d70",
        "hint": "#7ac0c0",
        "hint.background": "#7ac0c022",
        "hint.border": "#7ac0c0",
        "ignored": "#5a5d70",
        "info": "#7a9ad4",
        "info.background": "#7a9ad422",
        "info.border": "#7a9ad4",
        "modified": "#7a9ad4",
        "modified.background": "#7a9ad422",
        "modified.border": "#7a9ad4",
        "predictive": "#5a5d70",
        "renamed": "#7a9ad4",
        "success": "#7dc26d",
        "success.background": "#7dc26d22",
        "success.border": "#5a8c4a",
        "unreachable": "#5a5d70",
        "warning": "#d4a23f",
        "warning.background": "#d4a23f22",
        "warning.border": "#d4a23f",

        "players": [
          { "cursor": "#f4c860", "background": "#f4c860", "selection": "#f4c86033" },
          { "cursor": "#7a9ad4", "background": "#7a9ad4", "selection": "#7a9ad433" },
          { "cursor": "#7dc26d", "background": "#7dc26d", "selection": "#7dc26d33" },
          { "cursor": "#d48a9e", "background": "#d48a9e", "selection": "#d48a9e33" },
          { "cursor": "#7ac0c0", "background": "#7ac0c0", "selection": "#7ac0c033" },
          { "cursor": "#e85a4a", "background": "#e85a4a", "selection": "#e85a4a33" },
          { "cursor": "#d4a23f", "background": "#d4a23f", "selection": "#d4a23f33" },
          { "cursor": "#a04a64", "background": "#a04a64", "selection": "#a04a6433" }
        ],

        "syntax": {
          "attribute":            { "color": "#f4c860" },
          "boolean":              { "color": "#a04a64" },
          "comment":              { "color": "#5a5d70", "font_style": "italic" },
          "comment.doc":          { "color": "#bdb59d", "font_style": "italic" },
          "constant":             { "color": "#7ac0c0" },
          "constructor":          { "color": "#7a9ad4", "font_style": "italic" },
          "embedded":             { "color": "#e8e4d4" },
          "emphasis":             { "color": "#e8e4d4", "font_style": "italic" },
          "emphasis.strong":      { "color": "#f4c860", "font_weight": 700 },
          "enum":                 { "color": "#7ac0c0" },
          "function":             { "color": "#7a9ad4" },
          "function.method":      { "color": "#7a9ad4" },
          "hint":                 { "color": "#7ac0c0" },
          "keyword":              { "color": "#c93f3f" },
          "label":                { "color": "#c93f3f" },
          "link_text":            { "color": "#7a9ad4", "font_style": "italic" },
          "link_uri":             { "color": "#7a9ad4" },
          "number":               { "color": "#d48a9e" },
          "operator":             { "color": "#e85a4a" },
          "predictive":           { "color": "#5a5d70", "font_style": "italic" },
          "preproc":              { "color": "#a04a64" },
          "primary":              { "color": "#e8e4d4" },
          "property":             { "color": "#d48a9e" },
          "punctuation":          { "color": "#bdb59d" },
          "punctuation.bracket":  { "color": "#bdb59d" },
          "punctuation.delimiter":{ "color": "#bdb59d" },
          "punctuation.list_marker": { "color": "#c93f3f" },
          "punctuation.special":  { "color": "#f4c860" },
          "string":               { "color": "#d4a23f" },
          "string.escape":        { "color": "#f4c860" },
          "string.regex":         { "color": "#e85a4a" },
          "string.special":       { "color": "#f4c860" },
          "string.special.symbol":{ "color": "#7ac0c0" },
          "tag":                  { "color": "#c93f3f" },
          "text.literal":         { "color": "#d4a23f" },
          "title":                { "color": "#f4c860", "font_weight": 700 },
          "type":                 { "color": "#7ac0c0" },
          "variable":             { "color": "#e8e4d4" },
          "variable.parameter":   { "color": "#bdb59d", "font_style": "italic" },
          "variable.special":     { "color": "#a04a64", "font_style": "italic" },
          "variant":              { "color": "#7ac0c0" }
        }
